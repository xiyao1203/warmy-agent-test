{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "/var/folders/q3/3984dhy5635_6_mx_ych38d80000gn/T//agenttest-e2e.7mvxYs/next/types/**/*.ts",
    "/var/folders/q3/3984dhy5635_6_mx_ych38d80000gn/T//agenttest-e2e.7mvxYs/next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright"
  ]
}
